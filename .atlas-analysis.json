  "keyFeatures": [
    "Heritage destination management with rich multimedia support",
    "AI-powered tourist route generation based on proximity and preferences",
    "Interactive map-based route planning with Leaflet",
    "Role-based access control (Admin, Editor, Visitor)",
    "User tracking for visited POIs and completed routes",
    "Cloudinary integration for scalable media storage",
    "Clean Architecture with domain-driven design"
  ],
  "publicApiSurface": [
    "POST /auth/register - Register new user",
    "POST /auth/login - User authentication",
    "GET /destinos - List all destinations",
    "POST /destinos - Create destination (admin only)",
    "PUT /destinos/{id} - Update destination (admin only)",
    "DELETE /destinos/{id}/force - Delete destination (admin only)",
    "POST /destinos/{id}/multimedia - Upload media files (admin only)",
    "DELETE /destinos/{id}/multimedia - Remove media files (admin only)",
    "GET /rutas - List all tourist routes",
    "POST /rutas/crear - Create new route (editor+)",
    "GET /rutas/{id} - Get route details",
    "PUT /rutas/{id} - Update route (editor+)",
    "DELETE /rutas/{id} - Delete route (editor+)",
    "POST /rutas/generar-desde-poi - Generate route from POI",
    "POST /rutas/sugerencias - Get POI suggestions for route"
  ]
